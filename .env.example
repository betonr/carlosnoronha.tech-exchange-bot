# AwesomeAPI
AWESOMEAPI_KEY=your_key_here  # optional but recommended

# MongoDB
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/currency_worker?retryWrites=true&w=majority
MONGO_DB=currency_worker

# SMTP
SMTP_HOST=your.smtp.server
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_password
EMAIL_FROM=bot@yourdomain.com
EMAIL_TO=you@yourdomain.com
SMTP_USE_TLS=true
SMTP_START_TLS=false

# Fixed thresholds (BRL)
THRESHOLD_USD=6.20
THRESHOLD_EUR=6.80

# Historical analysis: notify if bid is X% above N-day average
AVERAGE_DAYS=30
AVERAGE_PERCENT_ABOVE=2.0

# Operating window (bot only runs within this hour range)
WINDOW_START=8
WINDOW_END=20

# Timezone
TZ=America/Sao_Paulo
